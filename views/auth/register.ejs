<div class="register-container">
    <h1>Register</h1>
    <form action="/auth/register" method="POST" autocomplete="off">
        <input type="text" name="name" placeholder="Name" autocomplete="name" required>
        <input type="email" name="email" placeholder="Email" autocomplete="email" required>
        <input type="password" name="password" placeholder="Password" autocomplete="new-password" required>
        <input type="password" name="confirmPassword" placeholder="Confirm Password" autocomplete="new-password"
            required>
        <button type="submit">Register</button>
    </form>
    <a href="/auth/login">Already have an account? Login here</a>
</div>