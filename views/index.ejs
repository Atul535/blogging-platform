<!-- Hero -->
<div class="hero">
    <div class="hero-badge">✦ Community Blog</div>
    <h1 class="hero-title">Welcome to my<br><span class="hero-accent">Blogging Platform</span></h1>
    <p class="hero-sub">Thoughts, ideas, and stories — crafted and shared.</p>
</div>

<!-- Create Post -->
<% if (user) { %>
    <div class="section-divider">
        <span>Create</span>
    </div>

    <div class="create-card">
        <div class="create-card-header">
            <div class="create-avatar">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path
                        d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" />
                </svg>
            </div>
            <div>
                <h2 class="create-title">New Post</h2>
                <p class="create-sub">Writing as <strong>
                        <%= user %>
                    </strong></p>
            </div>
        </div>

        <form action="/" method="POST" enctype="multipart/form-data" class="create-form">
            <div class="form-row">
                <div class="form-group">
                    <label for="title">Title</label>
                    <input type="text" id="title" name="title" placeholder="Give your post a title…" required>
                </div>
                <div class="form-group form-group--sm">
                    <label for="category">Category</label>
                    <select id="category" name="category">
                        <option value="Technology">🖥 Technology</option>
                        <option value="Lifestyle">🌿 Lifestyle</option>
                        <option value="Coding">💻 Coding</option>
                        <option value="Personal">✨ Personal</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="content">Content</label>
                <textarea id="content" name="content" placeholder="What's on your mind?" required></textarea>
            </div>
            <!-- Updated Selected File Name Tab with a Remove Button -->
            <div id="file-name-tab" class="file-info-tab" style="display: none;">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
                    <path
                        d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" />
                </svg>
                <span id="selected-file-name"></span>

                <!-- NEW: Remove Icon -->
                <button type="button" id="remove-file-btn" class="remove-file-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14"
                        height="14">
                        <path
                            d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
                    </svg>
                </button>
            </div>


            <div class="form-bottom">
                <label class="file-label" for="image">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16"
                        height="16">
                        <path
                            d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z" />
                    </svg>
                    Attach Image
                    <input type="file" id="image" name="image" accept="image/*">
                </label>
                <button type="submit" class="btn-submit">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16"
                        height="16">
                        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
                    </svg>
                    Publish Post
                </button>
            </div>
        </form>
    </div>
    <% } else { %>
        <div class="login-prompt">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
                <path
                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" />
            </svg>
            <span><a href="/auth/login">Login</a> or <a href="/auth/register">Register</a> to create posts.</span>
        </div>
        <% } %>
            <!-- Search & Filter Bar -->
            <div class="filter-section">
                <form action="/" method="GET" class="search-form">
                    <div class="search-input-wrapper">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18"
                            height="18">
                            <path
                                d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" />
                        </svg>
                        <input type="text" name="search" placeholder="Search posts…"
                            value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
                    </div>

                    <select name="category" onchange="this.form.submit()">
                        <option value="">All Categories</option>
                        <option value="Technology" <%=typeof categoryFilter !=='undefined' &&
                            categoryFilter==='Technology' ? 'selected' : '' %>>🖥 Technology</option>
                        <option value="Lifestyle" <%=typeof categoryFilter !=='undefined' &&
                            categoryFilter==='Lifestyle' ? 'selected' : '' %>>🌿 Lifestyle</option>
                        <option value="Coding" <%=typeof categoryFilter !=='undefined' && categoryFilter==='Coding'
                            ? 'selected' : '' %>>💻 Coding</option>
                        <option value="Personal" <%=typeof categoryFilter !=='undefined' && categoryFilter==='Personal'
                            ? 'selected' : '' %>>✨ Personal</option>
                    </select>

                    <button type="submit" class="btn-filter">Filter</button>

                    <% if ((typeof searchQuery !=='undefined' && searchQuery) || (typeof categoryFilter !=='undefined'
                        && categoryFilter)) { %>
                        <a href="/" class="clear-filters">Clear</a>
                        <% } %>
                </form>
            </div>

            <!-- Posts Section -->
            <div class="section-divider">
                <span>All Posts</span>
            </div>

            <% if(posts.length===0) { %>
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <p>No posts yet. Be the first to write something!</p>
                </div>
                <% } else { %>
                    <ul class="posts-grid">
                        <% posts.forEach(post=> { %>
                            <li class="post-card">
                                <% if (post.imageUrl) { %>
                                    <div class="post-image">
                                        <img src="<%= post.imageUrl %>" alt="Post Image">
                                    </div>
                                    <% } %>

                                        <div class="post-body">
                                            <div class="post-meta">
                                                <span
                                                    class="post-category-tag post-category-tag--<%= post.category ? post.category.toLowerCase() : 'default' %>">
                                                    <%= post.category || 'General' %>
                                                </span>
                                            </div>
                                            <h3 class="post-title">
                                                <%= post.title %>
                                            </h3>
                                            <p class="post-content">
                                                <%= post.content %>
                                            </p>
                                        </div>

                                        <% if (user) { %>
                                            <div class="post-footer">
                                                <form action="/delete/<%= post.id %>" method="POST">
                                                    <button type="submit" class="btn-delete">
                                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                            fill="currentColor" width="14" height="14">
                                                            <path
                                                                d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" />
                                                        </svg>
                                                        Delete
                                                    </button>
                                                </form>
                                            </div>
                                            <% } %>
                            </li>
                            <% }) %>
                    </ul>
                    <% } %>

                        <script>
                            const imageInput = document.getElementById('image');
                            const fileNameTab = document.getElementById('file-name-tab');
                            const fileNameText = document.getElementById('selected-file-name');
                            const removeFileBtn = document.getElementById('remove-file-btn');

                            // Show tab when file is selected
                            imageInput.addEventListener('change', function () {
                                const file = this.files[0];
                                if (file) {
                                    fileNameText.textContent = file.name;
                                    fileNameTab.style.display = 'inline-flex';
                                } else {
                                    fileNameTab.style.display = 'none';
                                }
                            });

                            // NEW: Handle the Remove button click
                            removeFileBtn.addEventListener('click', function () {
                                imageInput.value = ""; // This clears the selected file from the input
                                fileNameTab.style.display = 'none';
                                fileNameText.textContent = "";
                            });
                        </script>